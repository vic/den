---
import versions from './versions.json';
---

<select id="versions">
<option value="/">main</option>
{versions.map(v => <option value={"/"+v.name.replace("docs-","")}>{v.name.replace("docs-","")}</option>)}
</select>

<script>
  const versions = document.getElementById("versions");
  versions.addEventListener("change", _ => { document.location.pathname = versions.value; });
  document.querySelectorAll("#versions options").map(opt => {
    if (document.location.pathname.startsWith(opt.value)) { opt.selected = "selected"; }
  });
</script>
